# Copy to .env for local development, or set these in the Vercel dashboard
# (Project Settings -> Environment Variables) for the deployed demo.
#
# NEVER commit a real key. .env is git-ignored; keep secrets out of the repo.

# Groq API key. When set, answers are generated by a Groq-hosted model. When
# unset, the app runs fully on the deterministic extractive GraphRAG engine.
GROQ_API_KEY=

# Optional: override the default model (defaults to llama-3.3-70b-versatile).
# Other Groq options: openai/gpt-oss-120b, openai/gpt-oss-20b, llama-3.1-8b-instant
# LLM_MODEL=llama-3.3-70b-versatile

# Optional: maximum answer length in tokens (default 1024).
# LLM_MAX_TOKENS=1024

# Optional: sampling temperature (default 0.1, for grounded answers).
# LLM_TEMPERATURE=0.1

# Optional: number of document chunks retrieved per question (default 8).
# RETRIEVAL_TOP_K=8
